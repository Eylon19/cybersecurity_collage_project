<%- include('header') %>

<h1>מאמרי סייבר</h1>

<% if (user) { %>
    <a class="btn" href="/articles/add">הוספת מאמר</a>
<% } %>

<% if (articles.length > 0) { %>

    <% for (let i = 0; i < articles.length; i++) { %>

        <div class="card">

            <h2><%= articles[i].title %></h2>

            <p><strong>קטגוריה:</strong> <%= articles[i].category %></p>

            <p><strong>מחבר:</strong> <%= articles[i].author %></p>

            <p><strong>תקציר:</strong> <%= articles[i].summary %></p>

            <p><strong>רמת קושי:</strong> <%= articles[i].difficulty_level %></p>

            <p><strong>זמן קריאה:</strong> <%= articles[i].reading_time %> דקות</p>

            <p><strong>מקור:</strong> <%= articles[i].source_name %></p>

            <p><strong>תוכן:</strong></p>

            <p><%= articles[i].content %></p>

            <% if (user) { %>

                <a class="btn" href="/articles/edit/<%= articles[i].id %>">
                    עריכה
                </a>

                <form method="post"
                      action="/articles/delete/<%= articles[i].id %>"
                      style="display:inline;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="danger" type="submit">
                        מחיקה
                    </button>

                </form>

            <% } %>

        </div>

    <% } %>

<% } else { %>

    <p>אין מאמרים להצגה.</p>

<% } %>

<%- include('footer') %>
